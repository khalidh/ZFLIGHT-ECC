projection;
strict ( 2 );
use draft;

define behavior for ZF2_C_Order alias SalesOrder
{
  use create;
  use update;
  use delete;
  use action releaseOrder;
  use action createInvoice;
  use association _Items;
  use association _Invoice;
}

define behavior for ZF2_C_ORDER_ITEM alias SalesOrderItem
{
  use update;
  use delete;
}
