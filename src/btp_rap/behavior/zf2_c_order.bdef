projection;
strict ( 2 );
use draft;

define behavior for ZF2_C_Order alias SalesOrder
{
  use create;
  use update;
  use delete;
  use action releaseOrder;
  use action createInvoice;
  use association _Items { create; with draft; }
  use association _Invoice { create; with draft; }
}

define behavior for ZF2_C_OrderItem alias SalesOrderItem
{
  use update;
  use delete;
  use association _Order;
}

