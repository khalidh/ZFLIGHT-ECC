managed implementation in class zf2_bp_i_customer unique;
strict ( 2 );
with draft;

define behavior for ZF2_I_Customer alias Customer
persistent table zf2_customer
draft table zfl_d_customer
lock master
authorization master ( instance )
etag master LastChangedAt
{
  create;
  update;
  delete;

  association _Bookings;

  validation validateEmail on save { field EmailAddress; }
}

