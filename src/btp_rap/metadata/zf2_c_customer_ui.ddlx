@Metadata.layer: #CORE
annotate view ZF2_C_Customer with {
  @UI.facet: [
    { id: 'Customer', purpose: #STANDARD, type: #IDENTIFICATION_REFERENCE, label: 'Customer', position: 10 },
    { id: 'Bookings', purpose: #STANDARD, type: #LINEITEM_REFERENCE, label: 'Bookings', position: 20, targetElement: '_Bookings' }
  ]
  @UI.lineItem: [{ position: 10 }]
  @UI.selectionField: [{ position: 10 }]
  CustomerID;

  @UI.lineItem: [{ position: 20 }]
  LastName;

  @UI.lineItem: [{ position: 30 }]
  FirstName;

  @UI.lineItem: [{ position: 40 }]
  EmailAddress;

  @UI.lineItem: [{ position: 50 }]
  Vip;
}

