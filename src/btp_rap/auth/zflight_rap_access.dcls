@EndUserText.label: 'Flight RAP access control'
@MappingRole: true
define role ZFLIGHT_RAP_ACCESS {
  grant select on ZI_FlightCarrier where ( 1 = 1 );
  grant select on ZI_FlightConnection where ( 1 = 1 );
  grant select on ZI_Flight where ( 1 = 1 );
  grant select on ZI_Customer where ( 1 = 1 );
  grant select on ZI_Booking where ( 1 = 1 );
  grant select on ZI_Order where ( 1 = 1 );
  grant select on ZI_Invoice where ( 1 = 1 );
}

